        "archive/hetzner_version/runs/prod_refine_20260315_180520/stage03_candidate_audit/"
      ],
      "expected_hashes": {},
      "execution_class": "deterministic_replay",
      "default_enabled": false,
      "rerun_policy": "allowed_in_replay"
    },
    {
      "stage_id": "phase2_stage4_core_graph_construction",
      "phase": "Phase II",
      "description": "Construct historical Stage4 core graph from audited candidates.",
      "command": [
        "python",
        "archive/hetzner_version/src/kg_builder/relation_balanced_kg_pipeline.py",
        "--stage",
        "stage4"
      ],
      "inputs": [
        "archive/hetzner_version/runs/prod_refine_20260315_180520/stage03_candidate_audit/"
      ],
      "outputs": [
        "archive/hetzner_version/runs/prod_refine_20260315_180520/stage04_core_graph/"
      ],
      "expected_hashes": {},
      "execution_class": "graph_construction",
      "default_enabled": false,
      "rerun_policy": "never_by_default"
    },
    {
      "stage_id": "phase2_stage5_repair",
      "phase": "Phase II",
      "description": "Historical Stage5 graph repair.",
      "command": [
        "python",
        "archive/hetzner_version/src/kg_builder/relation_balanced_kg_pipeline.py",
        "--stage",
        "stage5"
      ],
      "inputs": [
        "archive/hetzner_version/runs/prod_refine_20260315_180520/stage04_core_graph/"
      ],
      "outputs": [
        "archive/hetzner_version/runs/prod_refine_20260315_180520/stage05_repair/"
      ],
      "expected_hashes": {},
      "execution_class": "graph_construction",
      "default_enabled": false,
      "rerun_policy": "never_by_default"
    },
    {
      "stage_id": "phase2_stage6_refinement",
      "phase": "Phase II",
      "description": "Historical Stage6 refinement.",
      "command": [
        "python",
        "archive/hetzner_version/src/kg_builder/relation_balanced_kg_pipeline.py",
        "--stage",
        "stage6"
      ],
      "inputs": [
        "archive/hetzner_version/runs/prod_refine_20260315_180520/stage05_repair/"
      ],
      "outputs": [
        "archive/hetzner_version/runs/prod_refine_20260315_180520/stage06_refinement/"
      ],
      "expected_hashes": {},
