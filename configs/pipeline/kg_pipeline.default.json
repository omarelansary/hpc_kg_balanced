    },
    {
      "stage_id": "phase2_stage11_connectivity_repair",
      "phase": "Phase II",
      "description": "Stage11 eta-aware connectivity repair output used by B0 reconstruction.",
      "command": [
        "python",
        "src/kg_building/repair_kg_connectivity.py"
      ],
      "inputs": [
        "src/Pruning graph/stage11_eta_aware_connectivity_repair_full/"
