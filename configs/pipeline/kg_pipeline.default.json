      "outputs": [
        "archive/hetzner_version/runs/prod_refine_20260315_180520/stage02_candidates/shards/"
      ],
      "expected_hashes": {},
      "execution_class": "driftable_live_wdqs",
      "default_enabled": false,
      "rerun_policy": "requires_explicit_live_flag"
    },
    {
      "stage_id": "phase2_stage3_candidate_audit",
